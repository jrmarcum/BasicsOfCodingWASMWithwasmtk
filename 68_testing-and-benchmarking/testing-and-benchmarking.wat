    (;; { a: 0, b: -1, want: -1 },;)
    (;; { a: -1, b: 0, want: -1 },;)
    (;; ];;)
        (i32.store (i32.const 0) (i32.const 300))
          (i32.store (i32.const 4) (i32.const 26))
          (drop (call $fd_write
            (i32.const 1)
            (i32.const 0)
            (i32.const 1)
            (i32.const 128)))
    (if (i32.ne (call $intMin (f64.const 2) (f64.const -2)) (i32.const -2))
